      <TestFragmentController guiclass="TestFragmentControllerGui" testclass="TestFragmentController" testname="Increase"/>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Increase">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters">${host_kafka} ${topic_operations} ${card_number} ${office_number}</stringProp>
          <stringProp name="script">import org.apache.kafka.clients.producer.KafkaProducer
import org.apache.kafka.clients.producer.ProducerRecord
import org.apache.kafka.common.serialization.StringSerializer
import java.util.Properties
import java.util.concurrent.ThreadLocalRandom

try {
    // 1. Получаем переменные из аргументов
    String hostKafka = args[0]?.trim() ?: &quot;localhost:9092&quot;
    String topic_operations = args[1]?.trim() ?: &quot;operations&quot;
    String cardNumber = args[2]?.replaceAll(&apos;&quot;&apos;, &apos;&apos;).trim()
    String officeNumberStr = args[3]?.replaceAll(&apos;&quot;&apos;, &apos;&apos;).trim()
    
    // 2. Логирование полученных значений
    log.info(&quot;-------------------Получены аргументы: host_kafka=${hostKafka}, topic_operations=${topic_operations}, card_number=${cardNumber}, office_number=${officeNumberStr}&quot;)
    
    // 3. Проверка обязательных переменных
    if (!cardNumber) throw new Exception(&quot;Не указан card_number&quot;)
    if (!officeNumberStr) throw new Exception(&quot;Не указан office_number&quot;)

    // 4. Настройки Kafka Producer
    Properties props = new Properties()
    props.put(&quot;bootstrap.servers&quot;, hostKafka)
    props.put(&quot;key.serializer&quot;, StringSerializer.class.getName())
    props.put(&quot;value.serializer&quot;, StringSerializer.class.getName())
    props.put(&quot;acks&quot;, &quot;1&quot;)
    props.put(&quot;retries&quot;, &quot;3&quot;)

    // 5. Создание Producer
    KafkaProducer&lt;String, String&gt; producer = new KafkaProducer&lt;&gt;(props)

    try {
        // 6. Преобразование office_number в число
        int officeNumber = officeNumberStr.toInteger()
        int amount = ThreadLocalRandom.current().nextInt(1000, 120000)
        
        // 7. Создание JSON
        String message = &quot;&quot;&quot;{
            &quot;card_number&quot;: &quot;${cardNumber.replace(&apos;&quot;&apos;, &apos;\\&quot;&apos;)}&quot;,
            &quot;amount&quot;: ${amount},
            &quot;operation_type&quot;: &quot;INCREASE&quot;,
            &quot;atm_number&quot;: &quot;ATM-1&quot;,
            &quot;office_number&quot;: &quot;${officeNumber}&quot;,
            &quot;currency_code&quot;: 1,
            &quot;operation_id&quot;: 2
        }&quot;&quot;&quot;
        
        // 8. Логирование перед отправкой
        log.info(&quot;Отправка сообщения на: ${hostKafka}, топик: ${topic_operations}&quot;)
        log.debug(&quot;Сообщение: ${message}&quot;)
        
        // 9. Отправка сообщения (ИСПРАВЛЕННАЯ СТРОКА)
        ProducerRecord&lt;String, String&gt; record = new ProducerRecord&lt;&gt;(topic_operations, message)
        producer.send(record)
        
        // 10. Установка статуса
        SampleResult.setSuccessful(true)
        SampleResult.setResponseMessage(&quot;Успешно отправлено для карты: ${cardNumber}&quot;)
    } catch (Exception e) {
        log.error(&quot;Ошибка отправки&quot;, e)
        SampleResult.setSuccessful(false)
        SampleResult.setResponseMessage(&quot;Ошибка: &quot; + e.getMessage())
    } finally {
        producer.close()
    }
} catch (Exception e) {
    log.error(&quot;Ошибка инициализации&quot;, e)
    SampleResult.setSuccessful(false)
    SampleResult.setResponseMessage(&quot;Ошибка инициализации: &quot; + e.getMessage())
}
