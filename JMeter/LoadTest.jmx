          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.util.Random;

// Генерация валидного ИНН физ.лица (12 цифр)
String generateValidIndividualINN() {
    Random random = new Random()
    StringBuilder inn = new StringBuilder()
    
    // 1. Генерируем первые 10 цифр случайно
    (1..10).each { inn.append(random.nextInt(10)) }
    
    // 2. Вычисляем первую контрольную цифру (11-я)
    int checksum1 = calculateINNChecksum(inn.toString(), 11)
    inn.append(checksum1)
    
    // 3. Вычисляем вторую контрольную цифру (12-я)
    int checksum2 = calculateINNChecksum(inn.toString(), 12)
    inn.append(checksum2)
    
    return inn.toString()
}

// Правильный расчет контрольных сумм для ИНН
int calculateINNChecksum(String partialInn, int position) {
    // Коэффициенты для расчетов
    def coefficients = [
        11: [7, 2, 4, 10, 3, 5, 9, 4, 6, 8],
        12: [3, 7, 2, 4, 10, 3, 5, 9, 4, 6, 8]
    ]
    
    int sum = 0
    coefficients[position].eachWithIndex { coeff, index -&gt;
        sum += Character.getNumericValue(partialInn.charAt(index)) * coeff
    }
    
    int remainder = sum % 11
    return (remainder &gt; 9) ? 0 : remainder
}

// Генерация и сохранение в переменную JMeter
try {
    String validINN = generateValidIndividualINN()
    vars.put(&quot;generated_inn&quot;, validINN)
    log.info(&quot;Generated valid INN: &quot; + validINN)
} catch (Exception e) {
    log.error(&quot;Error generating INN: &quot; + e.getMessage(), e)
    throw e
}

//ИНН физического лица (индивидуального предпринимателя) состоит из 12 цифр:
//1-4-я цифры — код налогового органа, который присвоил ИНН;
//5-10-я цифры — порядковый номер записи о лице в территориальном разделе Единого государственного реестра налогоплательщиков налогового органа, который присвоил ИНН;
//11-12-я цифры — контрольное число.



</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import org.apache.jmeter.protocol.http.sampler.HTTPSamplerProxy

try {
    // Получаем код ответа (универсальный способ)
    String responseCode = prev.getResponseCode()?.toString() ?: &quot;N/A&quot;
    
    // Обрабатываем HTTP и не-HTTP запросы
    if (sampler instanceof HTTPSamplerProxy) {
        vars.put(&quot;http_method&quot;, sampler.getMethod())
        vars.put(&quot;http_path&quot;, sampler.getPath())
    } else {
        vars.put(&quot;http_method&quot;, &quot;NON_HTTP&quot;)
        vars.put(&quot;http_path&quot;, sampler.getName())
    }
    
    // Проверяем, является ли код ответа числом (с корректным экранированием)
    boolean isNumeric = responseCode ==~ /^\d+$/  // Используем **Groovy-оператор ==~** вместо .matches()
    
    if (!isNumeric) {
        vars.put(&quot;responseCode&quot;, &quot;-1&quot;)  // Для нечисловых кодов
    } else {
        vars.put(&quot;responseCode&quot;, responseCode)
    }
    
    log.info(&quot;-------------------Request: ${sampler.getName()}, Method: ${vars.get(&apos;http_method&apos;)}, Path: ${vars.get(&apos;http_path&apos;)}, ResponseCode: ${vars.get(&apos;responseCode&apos;)}&quot;)
    
} catch (Exception e) {
    log.error(&quot;Error in PostProcessor: &quot;, e)
    vars.put(&quot;responseCode&quot;, &quot;-999&quot;)  // Код для ошибок скрипта
}</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
